{
  "name": "@lgrammel/agent-tui",
  "version": "0.1.0",
  "description": "Run AI SDK agents in a terminal UI.",
  "homepage": "https://github.com/lgrammel/agent-tui#readme",
  "bugs": {
    "url": "https://github.com/lgrammel/agent-tui/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lgrammel/agent-tui.git",
    "directory": "packages/agent-tui"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --tsconfig tsconfig.build.json",
    "prepack": "bun run prepare:publish && bun run build",
    "prepare:publish": "cp ../../README.md README.md && cp ../../LICENSE LICENSE",
    "pack:dry-run": "npm pack --dry-run",
    "release:dry-run": "bun run pack:dry-run",
    "release": "npm publish"
  },
  "dependencies": {
    "ai": "^7.0.0-canary.130"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
