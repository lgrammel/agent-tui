{
  "name": "agent-tui-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "type": "module",
  "scripts": {
    "check": "bun run format:check && bun run lint",
    "changeset": "changeset",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --deny-warnings",
    "package:build": "bun run --cwd packages/agent-tui build",
    "package:pack:dry-run": "bun run --cwd packages/agent-tui pack:dry-run",
    "package:release:dry-run": "bun run --cwd packages/agent-tui release:dry-run",
    "package:release": "bun run --cwd packages/agent-tui release",
    "release": "bun run package:build && changeset publish",
    "test": "vitest run --typecheck",
    "version-packages": "changeset version",
    "weather": "bun run --cwd examples/basic weather"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.8.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
